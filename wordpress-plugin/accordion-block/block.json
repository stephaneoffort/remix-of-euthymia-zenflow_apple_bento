{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "accordion-block/accordion",
  "version": "1.0.0",
  "title": "Accordéon",
  "category": "text",
  "icon": "list-view",
  "description": "Accordéon avec titres illimités et contenu enrichi.",
  "supports": {
    "html": false,
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "items": {
      "type": "array",
      "default": [
        { "title": "Titre 1", "content": "Votre contenu ici..." }
      ]
    }
  },
  "textdomain": "accordion-block",
  "editorScript": "file:./build/index.js",
  "editorStyle": "file:./build/index.css",
  "style": "file:./build/style-index.css",
  "viewScript": "file:./build/view.js"
}
